---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Replace with your actual data
const projects = [
  {
    title: "Project 1",
    description: "A description of your first project",
    image: "https://via.placeholder.com/800x600",
    technologies: ["React", "Node.js", "MongoDB"],
    link: "#"
  },
  {
    title: "Project 2",
    description: "A description of your second project",
    image: "https://via.placeholder.com/800x600",
    technologies: ["Vue.js", "Express", "PostgreSQL"],
    link: "#"
  }
];
---

<Layout title="Portfolio">
  <!-- Hero Section -->
  <section id="home" class="min-h-screen flex items-center pt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">
        Welcome to my <span class="text-gradient">Portfolio</span>
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 mb-8">
        Full Stack Developer passionate about creating modern web applications
      </p>
      <a
        href="#contact"
        class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>

  <!-- About Section -->
  <Section id="about" title="About Me" description="Learn more about my journey and skills">
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
      <div>
        <h3 class="text-2xl font-semibold mb-4">My Journey</h3>
        <p class="text-gray-600 dark:text-gray-400">
          Share your story, experience, and what drives you as a developer.
        </p>
      </div>
      <div>
        <h3 class="text-2xl font-semibold mb-4">Skills</h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <h4 class="font-semibold mb-2">Frontend</h4>
            <ul class="list-disc list-inside text-gray-600 dark:text-gray-400">
              <li>HTML & CSS</li>
              <li>JavaScript</li>
              <li>React</li>
              <li>Tailwind CSS</li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-2">Backend</h4>
            <ul class="list-disc list-inside text-gray-600 dark:text-gray-400">
              <li>Node.js</li>
              <li>Express</li>
              <li>MongoDB</li>
              <li>SQL</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Projects Section -->
  <Section id="projects" title="My Projects" description="Check out some of my recent work">
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </Section>

  <!-- Contact Section -->
  <Section id="contact" title="Contact Me" description="Let's work together">
    <div class="mt-12 max-w-xl mx-auto">
      <form class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium mb-2">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-800"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-800"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full px-4 py-2 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 dark:bg-gray-800"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
        >
          Send Message
        </button>
      </form>
    </div>
  </Section>
</Layout>
